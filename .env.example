# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your actual API keys.
#   cp .env.example .env
#
# .env is already listed in .gitignore — NEVER commit it to GitHub.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM Providers (set at least one) ─────────────────────────────────────────

# Groq  →  https://console.groq.com  (free tier available)
GROQ_API_KEY=gsk_your_groq_key_here

# OpenAI  →  https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your_openai_key_here

# Google Gemini  →  https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza_your_gemini_key_here

# ── Web Search ────────────────────────────────────────────────────────────────
# Serper.dev Google Search API  →  https://serper.dev
# Free plan: 2,500 queries/month, no credit card required
SERPER_API_KEY=your_serper_key_here

# ── Optional App Overrides ────────────────────────────────────────────────────
# Uncomment and change any of these to override the defaults in config.py

# Default LLM provider to use at startup  (groq | openai | gemini)
# DEFAULT_LLM_PROVIDER=groq

# Default model name for the chosen provider
# DEFAULT_MODEL=llama3-8b-8192

# Default response verbosity at startup  (concise | detailed)
# DEFAULT_RESPONSE_MODE=concise

# RAG chunking settings
# CHUNK_SIZE=800
# CHUNK_OVERLAP=100

# How many document chunks to retrieve per query
# TOP_K_CHUNKS=4

# Maximum number of chat turns kept in context
# MAX_CHAT_HISTORY=20

# Python logging level  (DEBUG | INFO | WARNING | ERROR)
# LOG_LEVEL=INFO
